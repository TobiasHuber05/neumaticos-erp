generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model asiento_detalle {
  id_as_detalle Int           @id @default(autoincrement())
  id_asiento    Int?
  id_cuenta     Int?
  debe_haber    Boolean?
  monto         Decimal?      @db.Decimal(18, 2)
  asientos      asientos?     @relation(fields: [id_asiento], references: [id_asiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_asientodetalle_asiento")
  plan_cuentas  plan_cuentas? @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_asientodetalle_cuenta")
}

model asientos {
  id_asiento         Int               @id @default(autoincrement())
  fecha              DateTime?         @db.Date
  numero_asiento     Int?
  descripcion        String?           @db.VarChar(250)
  total_debe         Decimal?          @db.Decimal(18, 2)
  total_haber        Decimal?          @db.Decimal(18, 2)
  estado             estado_asiento?   @default(pendiente)
  tabla_origen       String?           @db.VarChar(100)
  id_registro_origen Int?
  id_proc_contable   Int?
  asiento_detalle    asiento_detalle[]
  proceso_contable   proceso_contable? @relation(fields: [id_proc_contable], references: [id_proc_contable], onDelete: NoAction, onUpdate: NoAction, map: "fk_asientos_proceso")
}

model asistencia {
  id_asistencia      Int                  @id @default(autoincrement())
  dia                String?              @db.Char(30)
  inicio_turno       DateTime?            @db.Date
  final_turno        DateTime?            @db.Date
  detalle_asistencia detalle_asistencia[]
}

model balances {
  id_balance   Int       @id @default(autoincrement())
  tipo_balance String?   @db.VarChar(100)
  fecha        DateTime? @db.Date
}

model banco {
  id_banco        Int               @id @default(autoincrement())
  nombre          String?           @db.VarChar(100)
  codigo          String?           @db.Char(20)
  cuenta_bancaria cuenta_bancaria[]
}

model cabecera_pago {
  id_pago             Int                  @id @default(autoincrement())
  id_movimiento       Int?
  id_modelo_asiento   Int?
  fecha_emision       DateTime?            @db.Date
  periodo             String?              @db.VarChar(50)
  tipo_pago           String?              @db.VarChar(50)
  estado              estado_pago?         @default(pendiente)
  total               Decimal?             @db.Decimal
  modelo_asiento      modelo_asiento?      @relation(fields: [id_modelo_asiento], references: [id_modelo_asiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_cabecerapago_modeloasiento")
  movimiento_bancario movimiento_bancario? @relation(fields: [id_movimiento], references: [id_movimiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_cabecerapago_movimiento")
  detalle_pago        detalle_pago[]
  sueldos             sueldos[]
}

model cargos {
  id_cargo          Int            @id @default(autoincrement())
  nombre_cargo      String?        @db.VarChar(100)
  descripcion_cargo String?        @db.VarChar(250)
  area_superior     String?        @db.VarChar(100)
  jefe_inmediato    String?        @db.VarChar(100)
  sueldo_base       Decimal?       @db.Decimal(10, 2)
  contrato          contrato[]
  funcionarios      funcionarios[]
  historial         historial[]
}

model categoria {
  id_categoria Int        @id @default(autoincrement())
  nombre       String?    @db.VarChar(100)
  descripcion  String?    @db.VarChar(250)
  producto     producto[]
}

model categorias_proveedores {
  id_categoria         Int                    @id @default(autoincrement())
  tipo                 String?                @db.VarChar(50)
  descripcion          String?                @db.VarChar(250)
  proveedor_categorias proveedor_categorias[]
}

model cliente {
  id_cliente       Int             @id @default(autoincrement())
  nombre           String?         @db.VarChar(100)
  apellido         String?         @db.VarChar(100)
  fecha_nacimiento DateTime?       @db.Date
  correo           String?         @map("correo") @db.VarChar(50)
  ruc              String?         @map("ruc") @db.VarChar(20)
  direccion        String?         @db.VarChar(150)
  factura_venta    factura_venta[]
  presupuesto      presupuesto[]
}

model cobranza {
  id_cobranza            Int                  @id @default(autoincrement())
  id_factura_venta       Int?
  id_movimiento_bancario Int?
  nro_recibo             String?              @db.Char(50)
  factura_venta          factura_venta?       @relation(fields: [id_factura_venta], references: [id_factura_venta], onDelete: NoAction, onUpdate: NoAction, map: "fk_cobranza_factura")
  movimiento_bancario    movimiento_bancario? @relation(fields: [id_movimiento_bancario], references: [id_movimiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_cobranza_movimiento")
  detalle_cobranza       detalle_cobranza[]
}

model conceptos {
  id_concepto Int      @id @default(autoincrement())
  id_sueldo   Int?
  nombre      String?  @db.VarChar(50)
  descripcion String?  @db.VarChar(250)
  credito     Decimal? @db.Decimal(10, 2)
  debito      Decimal? @db.Decimal(10, 2)
  afecta_ips  Boolean?
  formula     String?  @db.VarChar(250)
  sueldos     sueldos? @relation(fields: [id_sueldo], references: [id_sueldo], onDelete: NoAction, onUpdate: NoAction, map: "fk_concepto_sueldo")
}

model conciliacion_bancaria {
  id_conciliacion      Int                    @id @default(autoincrement())
  id_cuenta            Int?
  fecha                DateTime?              @db.Date
  descripcion          String?                @db.VarChar(255)
  diferencia           Decimal?               @db.Decimal(15, 2)
  estado               String?                @default("Pendiente") @db.VarChar(20)
  monto_erp            Decimal?               @db.Decimal(15, 2)
  saldo_banco          Decimal?               @db.Decimal(15, 2)
  cuenta_bancaria      cuenta_bancaria?       @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_conciliacion_cuenta")
  detalle_conciliacion detalle_conciliacion[]
}

model contrato {
  id_contrato    Int           @id @default(autoincrement())
  id_funcionario Int?
  id_cargo       Int?
  id_sueldo      Int?
  fecha_ingreso  DateTime?     @db.Date
  fecha_salida   DateTime?     @db.Date
  salario_base   Decimal?      @db.Decimal(10, 2)
  cargos         cargos?       @relation(fields: [id_cargo], references: [id_cargo], onDelete: NoAction, onUpdate: NoAction, map: "fk_contrato_cargo")
  funcionarios   funcionarios? @relation(fields: [id_funcionario], references: [id_funcionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_contrato_funcionario")
  sueldos        sueldos?      @relation(fields: [id_sueldo], references: [id_sueldo], onDelete: NoAction, onUpdate: NoAction, map: "fk_contrato_sueldo")
}

model cotizacion {
  id_cotizacion      Int                  @id @default(autoincrement())
  id_pedido_producto Int?
  fecha              DateTime?            @db.Date
  id_proveedor       Int?
  pedidos_productos  pedidos_productos?   @relation(fields: [id_pedido_producto], references: [id_pedido_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_cotizacion_pedido")
  proveedores        proveedores?         @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: NoAction, onUpdate: NoAction, map: "fk_cotizacion_proveedor")
  detalle_cotizacion detalle_cotizacion[]
  orden_compra       orden_compra[]
}

model cuenta_bancaria {
  id_cuenta               Int                       @id @default(autoincrement())
  id_banco                Int?
  numero_cuenta           String?                   @db.Char(30)
  tipo_cuenta             String?                   @db.VarChar
  saldo                   Decimal?                  @db.Decimal(10, 2)
  saldo_disponible        Decimal?                  @db.Decimal(10, 2)
  id_moneda               Int?
  cheques_emitidos        cheques_emitidos[]
  conciliacion_bancaria   conciliacion_bancaria[]
  banco                   banco?                    @relation(fields: [id_banco], references: [id_banco], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_banco")
  monedas                 monedas?                  @relation(fields: [id_moneda], references: [id_moneda], onDelete: NoAction, onUpdate: NoAction, map: "fk_cuenta_moneda")
  movimiento_bancario     movimiento_bancario[]
  transferencias_emitidas transferencias_emitidas[]
}

model detalle_asistencia {
  id_detalle_asistencia Int           @id @default(autoincrement())
  id_asistencia         Int?
  id_funcionario        Int?
  justificativo         String?       @db.VarChar(250)
  asistencia            asistencia?   @relation(fields: [id_asistencia], references: [id_asistencia], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalleasistencia_asistencia")
  funcionarios          funcionarios? @relation(fields: [id_funcionario], references: [id_funcionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalleasistencia_funcionario")
}

model detalle_cobranza {
  id_detalle_cobranza Int       @id @default(autoincrement())
  id_cobranza         Int?
  forma_pago          String?   @db.VarChar(50)
  estado              String?   @db.VarChar(100)
  cobranza            cobranza? @relation(fields: [id_cobranza], references: [id_cobranza], onDelete: NoAction, onUpdate: NoAction, map: "fk_detcobranza_cobranza")
}

model detalle_conciliacion {
  id_detalle            Int                    @id @default(autoincrement())
  id_conciliacion       Int?
  id_movimiento         Int?
  conciliado            Boolean?
  conciliacion_bancaria conciliacion_bancaria? @relation(fields: [id_conciliacion], references: [id_conciliacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_detconc_conciliacion")
  movimiento_bancario   movimiento_bancario?   @relation(fields: [id_movimiento], references: [id_movimiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_detconc_movimiento")
}

model detalle_cotizacion {
  id_detalle_cotizacion Int         @id @default(autoincrement())
  id_cotizacion         Int?
  id_producto           Int?
  precio                Int?
  seleccionado          Boolean?
  cotizacion            cotizacion? @relation(fields: [id_cotizacion], references: [id_cotizacion], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallecotizacion_cotizacion")
  producto              producto?   @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallecotizacion_producto")
}

model detalle_devolucion {
  id_detalle_devolucion Int                 @id @default(autoincrement())
  id_devolucion         Int?
  id_producto_servicio  Int?
  cantidad              Int?
  devolucion_cliente    devolucion_cliente? @relation(fields: [id_devolucion], references: [id_devolucion], onDelete: NoAction, onUpdate: NoAction, map: "fk_detdev_devolucion")
  producto_servicio     producto_servicio?  @relation(fields: [id_producto_servicio], references: [id_producto_servicio], onDelete: NoAction, onUpdate: NoAction, map: "fk_detdev_producto")
}

model detalle_factura {
  id_detalle_factura Int             @id @default(autoincrement())
  id_factura_compra  Int?
  id_producto        Int?
  cantidad_recibida  Int?
  precio_unitario    Decimal?        @db.Decimal(18, 2)
  iva                Decimal?        @db.Decimal(18, 2)
  subtotal           Decimal?        @db.Decimal(18, 2)
  producto           producto?       @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallecotizacion_producto")
  factura_compra     factura_compra? @relation(fields: [id_factura_compra], references: [id_factura_compra], onDelete: NoAction, onUpdate: NoAction, map: "fk_detfact_factura")
}

model detalle_factura_venta {
  id_detalle_fac_venta Int                @id @default(autoincrement())
  id_factura_venta     Int?
  id_producto_servicio Int?
  cantidad             Int?
  precio_unitario      Decimal?           @db.Decimal(10, 2)
  iva                  Int?
  subtotal             Decimal?           @db.Decimal(10, 2)
  total                Decimal?           @db.Decimal(10, 2)
  factura_venta        factura_venta?     @relation(fields: [id_factura_venta], references: [id_factura_venta], onDelete: NoAction, onUpdate: NoAction, map: "fk_detfacventa_factura")
  producto_servicio    producto_servicio? @relation(fields: [id_producto_servicio], references: [id_producto_servicio], onDelete: NoAction, onUpdate: NoAction, map: "fk_detfacventa_producto")
}

model detalle_modelo_asiento {
  id_detalle_mod    Int             @id @default(autoincrement())
  id_modelo_asiento Int?
  item              Int?
  descripcion_final String?         @db.VarChar(250)
  id_cuenta         Int?
  debe_haber        Boolean?
  iva               Decimal?        @db.Decimal(10, 2)
  monto             Decimal?        @db.Decimal(10, 2)
  plan_cuentas      plan_cuentas?   @relation(fields: [id_cuenta], references: [id_cuenta], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallemodeloasiento_cuenta")
  modelo_asiento    modelo_asiento? @relation(fields: [id_modelo_asiento], references: [id_modelo_asiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallemodeloasiento_modeloasiento")
}

model detalle_nota_credito {
  id_detalle_nota       Int                 @id @default(autoincrement())
  id_nota_credito_venta Int?
  id_producto_servicio  Int?
  cantidad              Int?
  monto                 Decimal?            @db.Decimal(10, 2)
  nota_credito_venta    nota_credito_venta? @relation(fields: [id_nota_credito_venta], references: [id_nota_credito_venta], onDelete: NoAction, onUpdate: NoAction, map: "fk_detnotacred_nota")
  producto_servicio     producto_servicio?  @relation(fields: [id_producto_servicio], references: [id_producto_servicio], onDelete: NoAction, onUpdate: NoAction, map: "fk_detnotacred_producto")
}

model detalle_orden_compra {
  id_detalle_compra  Int           @id @default(autoincrement())
  id_orden_compra    Int?
  id_producto        Int?
  cantidad_pedida    Int?
  cantidad_entregada Int?          @default(0)
  precio_unitario    Decimal?      @db.Decimal(18, 2)
  subtotal           Decimal?      @db.Decimal(18, 2)
  orden_compra       orden_compra? @relation(fields: [id_orden_compra], references: [id_orden_compra], onDelete: NoAction, onUpdate: NoAction, map: "fk_detorden_orden")
  producto           producto?     @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detorden_producto")
}

model detalle_pago {
  id_detalle_pago Int            @id @default(autoincrement())
  id_pago         Int?
  descripcion     String?        @db.VarChar(250)
  cabecera_pago   cabecera_pago? @relation(fields: [id_pago], references: [id_pago], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallepago")
}

model detalle_presupuesto {
  id_detalle_presupuesto Int          @id @default(autoincrement())
  id_presupuesto         Int?
  id_producto            Int?
  cantidad_producto      Int?
  precio_unitario        Decimal?     @db.Decimal(10, 2)
  presupuesto            presupuesto? @relation(fields: [id_presupuesto], references: [id_presupuesto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detpres_presupuesto")
  producto               producto?    @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detpres_producto")
}

model detalle_provision {
  id_detalle_pp          Int                  @id @default(autoincrement())
  id_pedidos_proveedores Int?
  id_producto            Int?
  cantidad               Int
  monto                  Decimal?             @db.Decimal(10, 2)
  iva                    Decimal?             @db.Decimal(10, 2)
  precio_total           Decimal?             @db.Decimal(10, 2)
  producto               producto?            @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detalle_pedidoproveedores")
  pedidos_proveedores    pedidos_proveedores? @relation(fields: [id_pedidos_proveedores], references: [id_pedidos_proveedores], onDelete: NoAction, onUpdate: NoAction, map: "fk_detprov_pedidoprov")
}

model detalles_pedidos {
  id_detalle_pedido  Int                @id @default(autoincrement())
  id_pedido_producto Int?
  cantidad           Int?
  id_producto        Int?
  pedidos_productos  pedidos_productos? @relation(fields: [id_pedido_producto], references: [id_pedido_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallepedido_pedido")
  producto           producto?          @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_detallepedido_producto")
}

model devolucion_cliente {
  id_devolucion      Int                  @id @default(autoincrement())
  id_factura         Int?
  motivo_devolucion  String?              @db.VarChar(255)
  fecha_devolucion   DateTime?            @db.Date
  detalle_devolucion detalle_devolucion[]
  factura_venta      factura_venta?       @relation(fields: [id_factura], references: [id_factura_venta], onDelete: NoAction, onUpdate: NoAction, map: "fk_devcliente_factura")
  nota_credito_venta nota_credito_venta[]
}

model estados {
  id_estado    Int            @id @default(autoincrement())
  nombre       String         @db.VarChar(50)
  orden_compra orden_compra[]
}

model factura_compra {
  id_factura_compra           Int                           @id @default(autoincrement())
  id_orden_compra             Int?
  id_proveedor                Int?
  id_modelo_asiento           Int?
  fecha_emision               DateTime?                     @db.Date
  fecha_vencimiento           DateTime?                     @db.Date
  timbrado                    String?                       @db.VarChar(30)
  contado_credito             Boolean?
  total                       Decimal?                      @db.Decimal(18, 2)
  detalle_factura             detalle_factura[]
  detalle_orden_pago_facturas detalle_orden_pago_facturas[]
  orden_compra                orden_compra?                 @relation(fields: [id_orden_compra], references: [id_orden_compra], onDelete: NoAction, onUpdate: NoAction, map: "fk_factcompra_orden")
  proveedores                 proveedores?                  @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: NoAction, onUpdate: NoAction, map: "fk_factcompra_proveedor")
  modelo_asiento              modelo_asiento?               @relation(fields: [id_modelo_asiento], references: [id_modelo_asiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_modelo_asiento")
  pedido_devolucion           pedido_devolucion[]
}

model factura_venta {
  id_factura_venta      Int                     @id @default(autoincrement())
  id_presupuesto        Int?
  id_cliente            Int?
  id_modelo_asiento     Int?
  fecha_emision         DateTime?               @db.Date
  fecha_vencimiento     DateTime?               @db.Date
  timbrado              String?                 @db.VarChar(30)
  nro_factura           String?                 @db.VarChar(30)
  contado_credito       String?                 @db.VarChar(20)
  total                 Decimal?                @db.Decimal(10, 2)
  cobranza              cobranza[]
  detalle_factura_venta detalle_factura_venta[]
  devolucion_cliente    devolucion_cliente[]
  cliente               cliente?                @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction, map: "fk_factventa_cliente")
  presupuesto           presupuesto?            @relation(fields: [id_presupuesto], references: [id_presupuesto], onDelete: NoAction, onUpdate: NoAction, map: "fk_factventa_presupuesto")
  modelo_asiento        modelo_asiento?         @relation(fields: [id_modelo_asiento], references: [id_modelo_asiento], onDelete: NoAction, onUpdate: NoAction, map: "fk_modasiento")
}

model familiares {
  id_familiar      Int           @id @default(autoincrement())
  id_funcionario   Int?
  parentesco       String?       @db.VarChar(100)
  fecha_nacimiento DateTime?     @db.Date
  nombre           String?       @db.VarChar(150)  // nuevo
  cedula           String?       @db.VarChar(50)   // nuevo
  funcionarios     funcionarios? @relation(fields: [id_funcionario], references: [id_funcionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_familiares_funcionario")
}
model forma_pago {
  id_forma_pago         Int                     @id @default(autoincrement())
  metodo_pago           String?                 @db.VarChar(50)
  tipo_metodo           String?                 @db.VarChar(20)
  orden_pago_forma_pago orden_pago_forma_pago[]
}

model funcionarios {
  id_funcionario     Int                  @id @default(autoincrement())
  id_cargo           Int?
  id_horario         Int?
  id_persona         Int?
  contrato           contrato[]
  detalle_asistencia detalle_asistencia[]
  familiares         familiares[]
  cargos             cargos?              @relation(fields: [id_cargo], references: [id_cargo], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionarios_cargo")
  horario            horario?             @relation(fields: [id_horario], references: [id_horario], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionarios_horario")
  personas           personas?            @relation(fields: [id_persona], references: [id_persona], onDelete: NoAction, onUpdate: NoAction, map: "fk_funcionarios_persona")
  historial          historial[]
  usuarios           usuarios[]
}

model historial {
  id_historial   Int           @id @default(autoincrement())
  id_cargo       Int?
  id_funcionario Int?
  fecha_ingreso  DateTime?     @db.Date
  fecha_salida   DateTime?     @db.Date
  cargos         cargos?       @relation(fields: [id_cargo], references: [id_cargo], onDelete: NoAction, onUpdate: NoAction, map: "fk_historial_cargo")
  funcionarios   funcionarios? @relation(fields: [id_funcionario], references: [id_funcionario], onDelete: NoAction, onUpdate: NoAction, map: "fk_historial_funcionario")
}

model horario {
  id_horario     Int            @id @default(autoincrement())
  hora_entrada   DateTime?      @db.Time(6)
  hora_salida    DateTime?      @db.Time(6)
  dias_laborales String?        @db.VarChar(50)
  funcionarios   funcionarios[]
}

model lotes {
  id_lote           Int          @id @default(autoincrement())
  id_producto       Int?
  id_proveedor      Int?
  numero_lote       Int?
  fecha_produccion  DateTime?    @db.Date
  fecha_vencimiento DateTime?    @db.Date
  cantidad          Int?
  producto          producto?    @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction, map: "fk_lotes_producto")
  proveedores       proveedores? @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: NoAction, onUpdate: NoAction, map: "fk_lotes_proveedor")
}

model marcas {
  id_marca Int        @id @default(autoincrement())
  nombre   String?    @db.VarChar(100)
  producto producto[]
}

model modelo_asiento {
  id_modelo_asiento      Int                      @id @default(autoincrement())
  id_modulo              Int?
  descripcion            String?                  @db.VarChar(250)
  tipo_asiento           String?                  @db.VarChar(50)
  operacion_asiento      String?                  @db.VarChar(100)
